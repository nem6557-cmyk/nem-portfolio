<!-- 3-DOF reach arm.

gravcomp="1" on the moving links: the platform runs model-based gravity
compensation, as real impedance-controlled arms do, and the policy
commands residual torque. Without it this task is an exploration trap:
holding the arm up needs +2 to +4.3 N m at the shoulder, a zero-mean
exploration policy essentially never samples that region, every rollout
collapses into the same fallen pose, and returns carry no action
information. Measured, not theorized: corr(advantage, action noise)
was 0.02 to 0.07 with sign flips between batches, for this
implementation and for reference SB3 PPO alike.

Same "hardware" as projects 1 and 2: identical joint damping and dry
friction (the ground-truth values project 1 identifies), the same 6 N m
peak torque as project 2's actuator, with link and payload masses
sized so every target the environment samples is statically holdable
inside that torque budget (worst-case shoulder gravity torque ~4.3 N m, a 28% control margin).
The portfolio studies one arm four ways.

Joints: yaw (z), shoulder (y), elbow (y). Torque control, gear 1.
The target body is static and non-colliding; the environment moves it
by writing model.body_pos each reset.
-->
<mujoco model="reach_arm">
  <compiler angle="radian"/>
  <option timestep="0.005" gravity="0 0 -9.81" integrator="implicitfast"/>
  <default>
    <joint armature="0.01" limited="true"/>
    <geom rgba="0.55 0.6 0.66 1" friction="0.8 0.005 0.0001"/>
    <motor ctrllimited="true" ctrlrange="-6 6" gear="1"/>
  </default>

  <worldbody>
    <light pos="0.6 -0.8 1.6" dir="-0.3 0.4 -1"/>
    <geom name="floor" type="plane" size="1.5 1.5 0.05" rgba="0.12 0.15 0.19 1"/>
    <geom name="pedestal" type="cylinder" size="0.06 0.10" pos="0 0 0.10" rgba="0.25 0.28 0.33 1" contype="0" conaffinity="0"/>
    <!-- pedestal is decor only (contype 0): it interpenetrates the base
         link, so it must not collide. Note the compiler block above: MJCF
         parses angles as degrees by default, and ranges written as radians
         compile 57x too small, clamping the arm to a 2.6 degree cone. A
         scripted PD baseline plus qfrc_constraint inspection found it. -->

    <body name="base" pos="0 0 0.22">
      <joint name="yaw" type="hinge" axis="0 0 1" range="-2.6 2.6"
             damping="0.5" frictionloss="0.3"/>
      <geom type="cylinder" size="0.045 0.03"/>
      <body name="upperarm" pos="0 0 0.05" gravcomp="1">
        <joint name="shoulder" type="hinge" axis="0 1 0" range="-1.3 1.3"
               damping="0.4" frictionloss="0.25"/>
        <geom type="capsule" fromto="0 0 0 0.35 0 0" size="0.032" mass="0.6"/>
        <body name="forearm" pos="0.35 0 0" gravcomp="1">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-2.4 2.4"
                 damping="0.2" frictionloss="0.15"/>
          <geom type="capsule" fromto="0 0 0 0.30 0 0" size="0.026" mass="0.35"/>
          <body name="payload" pos="0.30 0 0" gravcomp="1">
            <geom name="tip" type="sphere" size="0.028" mass="0.25"
                  rgba="0.31 0.82 0.77 1"/>
            <site name="fingertip" pos="0 0 0" size="0.005"/>
          </body>
        </body>
      </body>
    </body>

    <body name="target" pos="0.4 0.2 0.4">
      <geom name="target_geom" type="sphere" size="0.022" rgba="1 0.54 0.36 0.9"
            contype="0" conaffinity="0"/>
      <site name="target_site" pos="0 0 0" size="0.004"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="m_yaw" joint="yaw"/>
    <motor name="m_shoulder" joint="shoulder"/>
    <motor name="m_elbow" joint="elbow"/>
  </actuator>
</mujoco>

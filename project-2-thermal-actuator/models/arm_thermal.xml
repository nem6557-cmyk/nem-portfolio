<mujoco model="arm3_highfidelity">
  <!-- Generated by build_arm.py. Inertials are analytic (see inertia.py),
       not auto-derived. Edit the design parameters in build_arm.py, not here. -->
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.001" integrator="RK4" gravity="0 0 -9.81"/>

  <default>
    <geom rgba="0.7 0.72 0.75 1" contype="0" conaffinity="0"/>
    <joint type="hinge" limited="false"/>
    <motor ctrlrange="-40 40" gear="1.0"/>
  </default>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" diffuse="0.9 0.9 0.9"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.25 0.26 0.28 1"/>

    <!-- fixed pedestal -->
    <geom name="pedestal" type="cylinder" fromto="0 0 0 0 0 0.1"
          size="0.05" rgba="0.35 0.36 0.38 1"/>

    <body name="link1" pos="0 0 0.1">
      <joint name="q1" axis="0 0 1" damping="0.5000" frictionloss="0.3000"/>
      <inertial pos="0.000000 0.000000 0.075000" mass="0.234111" fullinertia="5.013497e-04 5.013497e-04 1.247814e-04 0.000000e+00 0.000000e+00 0.000000e+00"/>
      <geom name="g_link1" type="cylinder" fromto="0 0 0 0 0 0.15" size="0.025"/>

      <body name="link2" pos="0 0 0.15">
        <joint name="q2" axis="0 1 0" damping="0.4000" frictionloss="0.2500"/>
        <inertial pos="0.150000 0.000000 0.000000" mass="0.282461" fullinertia="9.730768e-05 2.167108e-03 2.167108e-03 0.000000e+00 0.000000e+00 0.000000e+00"/>
        <geom name="g_link2" type="cylinder" fromto="0 0 0 0.3 0 0" size="0.020"/>

        <body name="link3" pos="0.3 0 0">
          <joint name="q3" axis="0 1 0" damping="0.2000" frictionloss="0.1500"/>
          <inertial pos="0.125000 0.000000 0.000000" mass="0.209937" fullinertia="5.762769e-05 1.122235e-03 1.122235e-03 0.000000e+00 0.000000e+00 0.000000e+00"/>
          <geom name="g_link3" type="cylinder" fromto="0 0 0 0.25 0 0" size="0.018"/>

          <body name="payload" pos="0.25 0 0">
            <inertial pos="0.000000 0.000000 0.000000" mass="0.500000" fullinertia="1.800000e-04 1.800000e-04 1.800000e-04 0.000000e+00 0.000000e+00 0.000000e+00"/>
            <geom name="g_payload" type="sphere" size="0.03"
                  rgba="0.85 0.45 0.2 1"/>
            <site name="tip" pos="0 0 0" size="0.008"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="m1" joint="q1"/>
    <motor name="m2" joint="q2"/>
    <motor name="m3" joint="q3"/>
  </actuator>

  <sensor>
    <jointpos joint="q1"/>
    <jointpos joint="q2"/>
    <jointpos joint="q3"/>
  </sensor>
</mujoco>
